local CoinFarmEnabled = false
local CoinFarmConnection = nil
local LastCoinRefresh = 0
local CachedCoins = {}
local CurrentCoin = nil
local CurrentCoinStartedAt = 0
local CoinCollectionTimeout = 1.25
local SkippedCoins = {}
local AutoGunPickupBusy = false

local function GetAllCoins()
	local now = os.clock()
	if now - LastCoinRefresh < 0.5 then
		return CachedCoins
	end
	LastCoinRefresh = now
	CachedCoins = {}
	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("BasePart") and obj.Name == "Coin_Server" and obj.Parent and obj.Parent.Name == "CoinContainer" then
			table.insert(CachedCoins, obj)
		end
	end
	return CachedCoins
end

local function EnableUndergroundMode(root)
	if not root then return end
	root.CanCollide = false
	for _, part in pairs(Player.Character:GetDescendants()) do
		if part:IsA("BasePart") then
			part.CanCollide = false
		end
	end
end

local function StartCoinFarm()
	if CoinFarmConnection then CoinFarmConnection:Disconnect() end
	CurrentCoin = nil
	CurrentCoinStartedAt = 0
	SkippedCoins = {}
	
	CoinFarmConnection = RunService.Heartbeat:Connect(function()
		if not CoinFarmEnabled then return end
		if AutoGunPickupBusy then return end
		
		local coins = GetAllCoins()
		if #coins == 0 then
			CoinFarmStatus.Text = "0"
			return
		end
		
		local root = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
		if not root then return end
		local now = os.clock()
		local availableCoins = {}
		for _, coin in ipairs(coins) do
			local skipUntil = SkippedCoins[coin]
			if not skipUntil or now >= skipUntil then
				SkippedCoins[coin] = nil
				table.insert(availableCoins, coin)
			end
		end

		if #availableCoins == 0 then
			CoinFarmStatus.Text = tostring(#coins)
			return
		end
		
		table.sort(availableCoins, function(a, b)
			return (root.Position - a.Position).Magnitude < (root.Position - b.Position).Magnitude
		end)
		
		local target = availableCoins[1]
		if target and target.Parent then
			if CurrentCoin ~= target then
				CurrentCoin = target
				CurrentCoinStartedAt = now
			elseif now - CurrentCoinStartedAt >= CoinCollectionTimeout then
				SkippedCoins[target] = now + 4
				CurrentCoin = nil
				CoinFarmStatus.Text = tostring(#coins)
				return
			end

			CoinFarmStatus.Text = tostring(#coins)
			root.CFrame = target.CFrame * CFrame.new(0, -3.5, 0)
			-- Extremely minimal delay for maximum speed
